{
  "expo": {
    "name": "Card Tracker",
    "slug": "friend-card-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "backgroundColor": "#0d0a0e"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "minSdkVersion": 24,
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "abiFilters": [
              "armeabi-v7a",
              "arm64-v8a",
              "x86",
              "x86_64"
            ]
          }
        }
      ]
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0d0a0e"
      },
      "package": "com.ayushman.cardtracker"
    },
    "ios": {
      "bundleIdentifier": "com.ayushman.cardtracker"
    },
    "extra": {
      "eas": {
        "projectId": "fd08fbcd-d0dc-44ed-878d-f4dd427fb199"
      }
    }
  }
}
